# SQLite
SQLITE_DB_PATH=./hybridsoc.db

# Superadmin bootstrap
SUPERADMIN_EMAIL=superadmin@hybridsoc.example.com
SUPERADMIN_PASSWORD=ChangeMeNow!123
ACCESS_TOKEN_TTL_MINUTES=60

# SMTP for email OTP delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer_user
SMTP_PASSWORD=mailer_password
SMTP_FROM=noreply@hybridsoc.local
SMTP_TLS=true

# IAM integrations
VAULT_ADDR=http://vault:8200
VAULT_ROLE=hybridsoc-pam
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=hybridsoc
