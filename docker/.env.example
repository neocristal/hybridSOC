# HybridSOC Environment Configuration
# Copy to .env and set all values before deployment
# NEVER commit .env to version control

# Wazuh
WAZUH_INDEXER_PASSWORD=changeme_strong_password_here

# TheHive
THEHIVE_SECRET=changeme_thehive_secret_32chars_min

# Cortex
CORTEX_SECRET=changeme_cortex_secret_32chars_min

# MISP
MISP_ADMIN_PASSWORD=changeme_misp_admin_password

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin_password

# HashiCorp Vault (dev mode only — use proper unsealing in production)
VAULT_DEV_ROOT_TOKEN=changeme_vault_root_token

# Password PEPPER (global secret for PBKDF2 hashing — 32 hex chars)
PASSWORD_PEPPER=changeme_generate_with_openssl_rand_hex_16

# Cloudflare Turnstile CAPTCHA
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=0x...
TURNSTILE_SITE_KEY=0x...

# SMTP (email OTP, notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@hybridsoc.ai
SMTP_PASS=changeme_smtp_password

# Application
APP_BASE_URL=http://localhost:5000
APP_ENV=development
